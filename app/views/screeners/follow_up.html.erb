<div class="hero min-h-screen bg-base-200">
  <div class="hero-content text-center">
    <div class="max-w-md">
      <h1 class="text-5xl font-bold">Thank You!</h1>
      <p class="py-6">Based on your results, your provider recommends you take the following screeners, as well:</p>
      <% @follow_up_results.each do |screener| %>
        <div class="card-actions justify-center">
          <button class="btn btn-block">
            <%= screener %>
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>